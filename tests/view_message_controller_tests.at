# Autotest tests for view_message_controller.c
# Covers the presentation-free kernel extracted from view_message_gui.c.

AT_BANNER([View Message Controller])

AT_SETUP([view_message_controller_init: default values correct])
AT_KEYWORDS([view_message view_message_controller init])
AT_CHECK(["$abs_top_builddir/tests/test_view_message_controller" init_default_values], [0], [PASS: view_message_controller_init: default values correct
])
AT_CLEANUP

