# Autotest tests for bulletin_controller.c
# Covers the presentation-free kernel extracted from bulletin_gui.c.

AT_BANNER([Bulletin Controller])

AT_SETUP([bulletin_controller_init: default values])
AT_KEYWORDS([bulletin bulletin_controller init])
AT_CHECK(["$abs_top_builddir/tests/test_bulletin_controller" init_default_values], [0], [PASS: bulletin_controller_init: default values
])
AT_CLEANUP

AT_SETUP([bulletin_controller_init: NULL is safe])
AT_KEYWORDS([bulletin bulletin_controller init null])
AT_CHECK(["$abs_top_builddir/tests/test_bulletin_controller" init_null_safe], [0], [PASS: bulletin_controller_init: NULL is safe
])
AT_CLEANUP

AT_SETUP([bulletin_controller_in_range: zero dist without view_zero])
AT_KEYWORDS([bulletin bulletin_controller in_range])
AT_CHECK(["$abs_top_builddir/tests/test_bulletin_controller" in_range_zero_dist_without_view_zero], [0], [PASS: bulletin_controller_in_range: zero dist rejected without view_zero
])
AT_CLEANUP

AT_SETUP([bulletin_controller_in_range: zero dist with view_zero])
AT_KEYWORDS([bulletin bulletin_controller in_range])
AT_CHECK(["$abs_top_builddir/tests/test_bulletin_controller" in_range_zero_dist_with_view_zero], [0], [PASS: bulletin_controller_in_range: zero dist accepted with view_zero
])
AT_CLEANUP

