# Autotest tests for geocoder_controller.c
# Covers the presentation-free kernel extracted from geocoder_gui.c.

AT_BANNER([Geocoder Controller])

AT_SETUP([geocoder_controller_init: default values])
AT_KEYWORDS([geocoder geocoder_controller init])
AT_CHECK(["$abs_top_builddir/tests/test_geocoder_controller" init_default_values], [0], [PASS: geocoder_controller_init: default values
])
AT_CLEANUP

AT_SETUP([geocoder_controller_init: NULL is safe])
AT_KEYWORDS([geocoder geocoder_controller init null])
AT_CHECK(["$abs_top_builddir/tests/test_geocoder_controller" init_null_safe], [0], [PASS: geocoder_controller_init: NULL is safe
])
AT_CLEANUP

AT_SETUP([geocoder_controller_country_count: positive count])
AT_KEYWORDS([geocoder geocoder_controller country_count])
AT_CHECK(["$abs_top_builddir/tests/test_geocoder_controller" country_count_positive], [0], [PASS: geocoder_controller_country_count: positive count
])
AT_CLEANUP

AT_SETUP([geocoder_controller_country_count: sentinel not counted])
AT_KEYWORDS([geocoder geocoder_controller country_count])
AT_CHECK(["$abs_top_builddir/tests/test_geocoder_controller" country_count_includes_sentinel], [0], [PASS: geocoder_controller_country_count: sentinel not counted
])
AT_CLEANUP

AT_SETUP([geocoder_controller_country_label: first entry])
AT_KEYWORDS([geocoder geocoder_controller country_label])
