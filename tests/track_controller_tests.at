# Autotest tests for track_controller.c
# Covers the presentation-free kernel extracted from track_gui.c.

AT_BANNER([Track Controller])

AT_SETUP([track_controller_init: default values])
AT_KEYWORDS([track track_controller init])
AT_CHECK(["$abs_top_builddir/tests/test_track_controller" init_default_values], [0], [PASS: track_controller_init: default values
])
AT_CLEANUP

AT_SETUP([track_controller_init: NULL is safe])
AT_KEYWORDS([track track_controller init null])
AT_CHECK(["$abs_top_builddir/tests/test_track_controller" init_null_safe], [0], [PASS: track_controller_init: NULL is safe
])
AT_CLEANUP

AT_SETUP([track_controller_set_station: valid call accepted])
AT_KEYWORDS([track track_controller set_station])
AT_CHECK(["$abs_top_builddir/tests/test_track_controller" set_station_valid_call], [0], [PASS: track_controller_set_station: valid call accepted
])
AT_CLEANUP

