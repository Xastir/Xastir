# Main Autotest suite for Xastir 
# This file defines the test suite structure

AT_INIT([Xastir Tests])
AT_COPYRIGHT([Copyright (C) 2025-2026 The Xastir Group])

AT_COLOR_TESTS

# Include interface helper function tests
m4_include([interface_helpers.at])

# Include database function tests
m4_include([db_tests.at])

# Include output_my_aprs_data function tests
m4_include([output_my_aprs_data_tests.at])

# Include object utility function tests
m4_include([object_utils_tests.at])

# Include basic utility function tests
m4_include([util_tests.at])

# Include basic objects function tests
m4_include([objects_tests.at])

# Include popup controller tests (presentation/logic-separation migration)
m4_include([popup_controller_tests.at])

# Include location controller tests (presentation/logic-separation migration)
m4_include([location_controller_tests.at])

# Include view_message controller tests (presentation/logic-separation migration)
m4_include([view_message_controller_tests.at])

# Include bulletin controller tests (presentation/logic-separation migration)
m4_include([bulletin_controller_tests.at])

# Include track controller tests (presentation/logic-separation migration)
m4_include([track_controller_tests.at])

# Include nominatim geocoding tests (conditionally compiled if HAVE_NOMINATIM)
m4_ifdef([HAVE_NOMINATIM], [
m4_include([nominatim_tests.at])
])
