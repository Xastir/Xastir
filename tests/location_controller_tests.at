# Autotest tests for location_controller.c
# Covers the presentation-free kernel extracted from location_gui.c.

AT_BANNER([Location Controller])

AT_SETUP([location_controller_init: stores paths])
AT_KEYWORDS([location location_controller init])
AT_CHECK(["$abs_top_builddir/tests/test_location_controller" init_zeroes_state], [0], [PASS: location_controller_init: stores paths
])
AT_CLEANUP

AT_SETUP([location_controller_init: NULL paths stored as empty])
AT_KEYWORDS([location location_controller init])
AT_CHECK(["$abs_top_builddir/tests/test_location_controller" init_null_paths_are_empty], [0], [PASS: location_controller_init: NULL paths stored as empty
])
AT_CLEANUP

